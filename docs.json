{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "PrismaFlow",
  "description": "Documentação oficial do PrismaFlow — guia de uso e integração.",
  "colors": {
    "primary": "#6950E8",
    "light": "#8C8DFF",
    "dark": "#6950E8"
  },
  "appearance": {
    "default": "dark",
    "strict": true
  },
  "background": {
    "color": {
      "dark": "#111827"
    }
  },
  "styling": {
    "codeblocks": "dark"
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logo/icon.svg",
    "dark": "/logo/icon.svg"
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Comece aqui",
        "groups": [
          {
            "group": "Início",
            "pages": [
              "index"
            ]
          },
          {
            "group": "Eventos",
            "pages": [
              "eventos/definicoes",
              "eventos/computed-traits",
              "eventos/identidades",
              "eventos/quarentena"
            ]
          },
          {
            "group": "Audiência",
            "pages": [
              {
                "group": "Segmentos",
                "icon": "users",
                "root": "audiencia/segmentos",
                "expanded": true,
                "pages": [
                  "audiencia/tipos-de-clausula"
                ]
              }
            ]
          },
          {
            "group": "Jornadas",
            "pages": [
              {
                "group": "Jornadas",
                "icon": "route",
                "root": "jornadas/visao-geral",
                "expanded": true,
                "pages": [
                  "jornadas/gatilhos",
                  "jornadas/nos",
                  "jornadas/ciclo-de-vida"
                ]
              }
            ]
          }
        ]
      }
    ]
  },
  "navbar": {
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://dashboard.prismacdp.com"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/prismaflow",
      "x": "https://x.com/prismaflow"
    }
  }
}
